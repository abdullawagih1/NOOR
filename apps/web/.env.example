# Public — safe for the browser bundle
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Used to build absolute redirect URLs (password reset, auth callback).
# Local dev: http://localhost:3000. Preview/Production: the deployed origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only — NEVER prefix with NEXT_PUBLIC_, never read from client components.
SUPABASE_SERVICE_ROLE_KEY=
WORKER_BASE_URL=
WORKER_INTERNAL_TOKEN=
