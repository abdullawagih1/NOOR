# =========================================================
# Noor Web — Next.js / Vercel
# Validated at runtime by lib/env/public.ts (browser-safe) and
# lib/env/server.ts (server-only). See docs/operations/environment-variables.md.
# =========================================================

APP_ENV=development

# Public — safe for the browser bundle
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Used to build absolute redirect URLs (password reset, auth callback).
# Local dev: http://localhost:3000. Preview/Production: the deployed origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only — NEVER prefix with NEXT_PUBLIC_, never read from client components.
SUPABASE_SERVICE_ROLE_KEY=

# Worker integration — server only, optional until Sprint 1 wires a real call site.
WORKER_BASE_URL=
WORKER_INTERNAL_TOKEN=
