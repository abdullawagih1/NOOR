# =========================================================
# Noor Worker — Python / FastAPI
# Validated at startup by app/settings.py (pydantic-settings). A missing or
# malformed WORKER_INTERNAL_TOKEN crashes the process at import time — see
# docs/operations/environment-variables.md.
# =========================================================

WORKER_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080

# Not consumed by any code path yet (Sprint 1) — optional.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Required. Protects POST /jobs. Generate with: openssl rand -hex 32
# Never commit a real value here.
WORKER_INTERNAL_TOKEN=

WEB_APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Not required until AI Gateway implementation exists — optional.
AI_GATEWAY_PROVIDER=
AI_GATEWAY_API_KEY=
