# =========================================================
# Noor — shared environment template (aggregate reference only)
#
# This file documents every variable category across the monorepo so you
# can see the whole picture in one place. It is NOT read by any app at
# runtime — copy the relevant values into the app-specific file you
# actually need:
#   apps/web/.env.local     (Next.js — see apps/web/.env.example)
#   apps/worker/.env        (FastAPI worker — see apps/worker/.env.example)
#
# Never commit an actual .env/.env.local file — see SECURITY.md.
# Full reference, classification, rotation, and incident-response guidance:
#   docs/operations/environment-variables.md
# =========================================================

# --- Application -------------------------------------------------------
APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase — browser-safe (apps/web only) ----------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase — server only (apps/web and apps/worker) ------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Worker integration — server only (apps/web -> apps/worker) ---------
WORKER_BASE_URL=
WORKER_INTERNAL_TOKEN=

# --- AI Gateway — not required until AI implementation exists -----------
AI_GATEWAY_PROVIDER=
AI_GATEWAY_API_KEY=
